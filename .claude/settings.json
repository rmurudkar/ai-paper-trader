{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-sonnet-4-20250514",
  "maxTokens": 4096,
  
  "permissions": {
    "allow": [
      "Bash",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git stash *)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(git merge *)",
      "Bash(git tag *)",
      "Bash(git show *)",
      "Bash(git blame *)",
      "Bash(git remote *)",
      "Bash(git config *)",
      "Bash(git clone *)",
      "Bash(git init *)",
      "Read",
      "Write",
      "Edit"
    ],
    
    "deny": [
      "Read(./.env.local)",
      "Read(./.env.*.local)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.*.local)",
      "Edit(./.env)",
      "Edit(./.env.local)",
      "Edit(./.env.*.local)",
      "Edit(.env)",
      "Edit(.env.local)",
      "Edit(.env.*.local)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(sudo:*)"
    ]
  },
  
  "statusLine": {
    "type": "command",
    "command": "echo '🔒 Limited git access (no add/commit/push) | ✅ All bash | 🚫 .env blocked'"
  },
  
  "alwaysThinkingEnabled": true
}